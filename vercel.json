{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/walks/(.*)", "destination": "/api/walks" },
    { "source": "/api/auth/(.*)", "destination": "/api/auth" },
    { "source": "/api/iot/(.*)", "destination": "/api/iot" },
    { "source": "/api/ai/(.*)", "destination": "/api/ai" },
    { "source": "/api/uploads/(.*)", "destination": "/api/uploads" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
