{
  "name": "gemba-rounds",
  "version": "1.0.0",
  "description": "AI-powered Gemba Walk application for operational excellence",
  "main": "src/server/index.js",
  "scripts": {
    "start": "node src/server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon src/server/index.js",
    "client": "cd src/public && npm start",
    "build": "cd src/public && npm run build",
    "install-all": "npm install && cd src/public && npm install"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "markdown-pdf": "^11.0.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "gemba",
    "lean",
    "operational-excellence",
    "ai",
    "iot"
  ],
  "author": "GembaRounds Team",
  "license": "MIT"
}
