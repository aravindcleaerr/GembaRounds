# GembaRounds Environment Configuration
# Copy this file to .env and update with your values

# MongoDB Atlas connection string (or local MongoDB URI)
# For Atlas: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/gembarounds
# For local: mongodb://localhost:27017/gembarounds
MONGO_URI=mongodb://localhost:27017/gembarounds

# JWT Secret - change this to a random string in production
JWT_SECRET=gembarounds-secret-key-change-in-production

# Server port
PORT=3000
